<?xml version="1.0" encoding="utf-8"?>
<!-- Уведомление со списком задач. Путь C: свой небесно-синий фон на ВЕСЬ блок + белый текст.
     Фон на внешнем контейнере, отрицательные margin съедают системный отступ уведомления,
     чтобы заливка шла до краёв, а не куском. Цвет фиксированный (под тему не меняется —
     это ограничение кастомного RemoteViews на MIUI). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginLeft="-16dp"
    android:layout_marginRight="-16dp"
    android:layout_marginTop="-10dp"
    android:layout_marginBottom="-10dp"
    android:background="#3BA9F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- Шапка: заголовок + подпись справа -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/notif_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:text="Задачи на сегодня" />

        <TextView
            android:id="@+id/notif_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#E3F2FD"
            android:text="" />
    </LinearLayout>

    <!-- Строка 0 -->
    <LinearLayout
        android:id="@+id/row_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/row_0_time"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:text="" />

        <TextView
            android:id="@+id/row_0_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:text="" />
    </LinearLayout>

    <!-- Строка 1 -->
    <LinearLayout
        android:id="@+id/row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/row_1_time"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:text="" />

        <TextView
            android:id="@+id/row_1_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:text="" />
    </LinearLayout>

    <!-- Строка 2 -->
    <LinearLayout
        android:id="@+id/row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/row_2_time"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:text="" />

        <TextView
            android:id="@+id/row_2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:text="" />
    </LinearLayout>

    <!-- Строка 3 -->
    <LinearLayout
        android:id="@+id/row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/row_3_time"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:text="" />

        <TextView
            android:id="@+id/row_3_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:text="" />
    </LinearLayout>

    <!-- Строка 4 -->
    <LinearLayout
        android:id="@+id/row_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/row_4_time"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:text="" />

        <TextView
            android:id="@+id/row_4_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:text="" />
    </LinearLayout>

    </LinearLayout>
</LinearLayout>
